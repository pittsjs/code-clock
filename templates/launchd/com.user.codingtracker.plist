<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.user.codingtracker</string>
    <key>ProgramArguments</key>
    <array>
        <string>__PYTHON__</string>
        <string>__SCRIPT_DIR__/tracker.py</string>
    </array>
    <key>WorkingDirectory</key>
    <string>__SCRIPT_DIR__</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>__HOME__/.coding_tracker_stdout.log</string>
    <key>StandardErrorPath</key>
    <string>__HOME__/.coding_tracker_stderr.log</string>
</dict>
</plist>
